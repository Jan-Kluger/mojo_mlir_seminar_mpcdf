@inproceedings{akreComprehensiveReviewMojo2025,
  title = {A {{Comprehensive Review}} of {{Mojo}}: {{A High-Performance Programming Language}}},
  shorttitle = {A {{Comprehensive Review}} of {{Mojo}}},
  booktitle = {2025 6th {{International Conference}} on {{Mobile Computing}} and {{Sustainable Informatics}} ({{ICMCSI}})},
  author = {Akre, Parth Dhananjay and Pacharaney, Utkarsha},
